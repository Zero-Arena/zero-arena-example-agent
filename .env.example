# Your SDK consumer config. Copy to `examples/.env` and fill PRIVATE_KEY.

ZA_RPC=https://evmrpc.0g.ai
ZA_INDEXER=https://indexer-storage-turbo.0g.ai

# Your wallet. Signs your certify + mintAgent tx, pays your gas, owns your iNFT.
# Fund this address with 0G on mainnet before running.
PRIVATE_KEY=0x

# 0G mainnet deployment (chainId 16661). Pinned in @zero-arena/contracts.
ZA_ADDR_CERT=0x21a5DEA59cfA07B261d389A9554477e137805c2f
ZA_ADDR_INFT=0x4Bd4d45f206861aa7cD4421785a316A1dD06036f
ZA_ADDR_ORACLE=0x63909dA30b0d65ad72b32b3C8C82515f7BFA6Fd6

# Arena layer — needed by scripts/{create-season,enroll-all,season-status}.ts.
ZA_ADDR_LIVE_CERT=0x168c244c872f5FC2D737D3126D08e9EEE45fFbc7
ZA_ADDR_SEASON=0x4e900860565F9D399B7295c0D28CC7954202524e

# Optional — defaults to ~/.zeroarena/keys
# ZA_KEYS_DIR=
